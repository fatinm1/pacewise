# Strava OAuth (get refresh_token via OAuth flow; see README)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=


# BigQuery: path to service account JSON. For Docker, copy key to keys/service-account.json
# (container uses /opt/pacewise/keys/service-account.json via docker-compose).
GOOGLE_APPLICATION_CREDENTIALS=/path/to/your-service-account.json
#
# Railway / hosted deployments:
# - Do NOT use a macOS path like /Users/... — containers can't see your laptop filesystem.
# - Prefer inline JSON credentials for the Next.js server runtime:
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account", ...}
# Or base64:
# GOOGLE_APPLICATION_CREDENTIALS_B64=...
BIGQUERY_PROJECT_ID=
BIGQUERY_DATASET=pacewise_raw
# Where dbt writes staging/marts (and what the Next.js API queries)
BIGQUERY_ANALYTICS_DATASET=pacewise

# Optional: BigQuery location for queries/datasets (default: US)
# BIGQUERY_LOCATION=US

# Optional: HR zone configuration used by dbt model mart_hr_zones_weekly
# HR_MAX_BPM=190
# HR_ZONE_Z1_MAX=0.60
# HR_ZONE_Z2_MAX=0.70
# HR_ZONE_Z3_MAX=0.80
# HR_ZONE_Z4_MAX=0.90

# Airflow: email for failure alerts (optional)
AIRFLOW_ADMIN_EMAIL=

# Optional: path to Strava token JSON (default: strava_tokens.json)
# STRAVA_TOKEN_FILE=./strava_tokens.json

# Optional: force the dashboard to use mock data even if the API is available
# (set this in pacewise-frontend/.env.local for local dev, or as a Railway env var)
# NEXT_PUBLIC_USE_MOCK_DATA=0

# --- PaceWise Next.js: free local mode (no BigQuery) ---
# Auto: local JSON store when BIGQUERY_PROJECT_ID is unset; BigQuery when it is set.
# PACEWISE_DATA_SOURCE=local
# PACEWISE_DATA_SOURCE=bigquery
# Path to activities JSON (default: <frontend cwd>/data/activities.json). Mount a volume on Railway to persist.
# PACEWISE_LOCAL_DATA_PATH=/data/activities.json
# Display name in local mode athlete summary
# PACEWISE_ATHLETE_NAME=Local Athlete
